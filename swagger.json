{
  "openapi": "3.0.0",
  "info": {
    "title": "To-Do List API",
    "description": "A comprehensive RESTful API for managing tasks with JWT authentication, rate limiting, and advanced filtering capabilities.",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Bearer token for API authentication. Access tokens are valid for 15 minutes."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "Unique user identifier"
          },
          "username": {
            "type": "string",
            "example": "john_doe",
            "description": "Unique username (3-80 characters)"
          }
        },
        "required": ["username"]
      },
      "Todo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "Unique todo identifier"
          },
          "title": {
            "type": "string",
            "example": "Complete project documentation",
            "description": "Todo title (required, max 100 characters)"
          },
          "description": {
            "type": "string",
            "example": "Write comprehensive documentation for the API project",
            "description": "Optional todo description (max 500 characters)"
          },
          "status": {
            "type": "string",
            "enum": ["open", "in progress", "completed"],
            "example": "open",
            "default": "open",
            "description": "Current status of the todo"
          }
        },
        "required": ["title"]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "john_doe",
            "description": "Unique username"
          },
          "password": {
            "type": "string",
            "example": "SecurePassword123",
            "description": "User password"
          }
        },
        "required": ["username", "password"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "john_doe"
          },
          "password": {
            "type": "string",
            "example": "SecurePassword123"
          }
        },
        "required": ["username", "password"]
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "description": "JWT access token (valid for 15 minutes)"
          },
          "refresh_token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "description": "JWT refresh token (valid for 7 days)"
          }
        }
      },
      "TodoCreateRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Buy groceries",
            "description": "Title of the todo (required)"
          },
          "description": {
            "type": "string",
            "example": "Get milk, eggs, and bread from the store",
            "description": "Description of the todo (optional)"
          }
        },
        "required": ["title"]
      },
      "TodoUpdateRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Buy groceries and cook dinner"
          },
          "description": {
            "type": "string",
            "example": "Get milk, eggs, bread and plan dinner"
          },
          "status": {
            "type": "string",
            "enum": ["open", "in progress", "completed"],
            "example": "in progress"
          }
        }
      },
      "TodoResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Buy groceries"
          },
          "description": {
            "type": "string",
            "example": "Get milk, eggs, and bread"
          },
          "status": {
            "type": "string",
            "enum": ["open", "in progress", "completed"],
            "example": "open"
          }
        }
      },
      "TodoListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TodoResponse"
            }
          },
          "page": {
            "type": "integer",
            "example": 1
          },
          "limit": {
            "type": "integer",
            "example": 10
          },
          "total": {
            "type": "integer",
            "example": 25,
            "description": "Total number of todos matching the filter criteria"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "error": {
            "type": "string",
            "description": "Error type (for certain error codes)"
          }
        }
      }
    }
  },
  "paths": {
    "/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "description": "Create a new user account. Rate limit: 5 requests per minute per IP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "username": "john_doe",
                "password": "MySecurePassword123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "User successfully Registered. Please login"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - username already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "data": "username already exists"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded - 5 requests per minute",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "ratelimit_exceeded"
                    },
                    "message": {
                      "type": "string",
                      "example": "Whoa there! You have exceeded your rate limit."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login user",
        "description": "Authenticate user and receive access and refresh tokens. Rate limit: 5 requests per minute per IP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "username": "john_doe",
                "password": "MySecurePassword123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "user_not_found": {
                    "value": {
                      "data": "No username with john_doe found"
                    }
                  },
                  "wrong_password": {
                    "value": {
                      "data": "Wrong Password"
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded - 5 requests per minute",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "ratelimit_exceeded"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/refresh": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Refresh access token",
        "description": "Use refresh token to obtain a new access token. Refresh tokens are valid for 7 days. Rate limit: 5 requests per minute per IP",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Token refreshed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - token not provided",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Please provide the token"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token issues",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "expired_token": {
                    "value": {
                      "message": "Token is Expired!"
                    }
                  },
                  "invalid_token": {
                    "value": {
                      "message": "Token is Invalid!"
                    }
                  },
                  "access_token_provided": {
                    "value": {
                      "message": "Need Refresh token to provide new token"
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded - 5 requests per minute",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/todos": {
      "post": {
        "tags": ["Todos"],
        "summary": "Create a new todo",
        "description": "Create a new todo item for the authenticated user",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoCreateRequest"
              },
              "example": {
                "title": "Complete API documentation",
                "description": "Write comprehensive Swagger documentation for all endpoints"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Todo created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - title is required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Title is required"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token missing, invalid, or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missing_token": {
                    "value": {
                      "message": "Token is missing!"
                    }
                  },
                  "expired_token": {
                    "value": {
                      "message": "Token is Expired!"
                    }
                  },
                  "invalid_token": {
                    "value": {
                      "message": "Token is Invalid!"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Internal Server Issue! Please try again later"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Todos"],
        "summary": "Get all todos",
        "description": "Retrieve paginated list of todos for the authenticated user with optional filtering, sorting, and searching",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination (default: 1)",
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of todos per page (default: 10)",
            "schema": {
              "type": "integer",
              "example": 10
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by todo status",
            "schema": {
              "type": "string",
              "enum": ["open", "in progress", "completed"]
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Sort todos by field (title, status, or id)",
            "schema": {
              "type": "string",
              "enum": ["title", "status", "id"]
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order (asc or desc). Used with sort_by parameter",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"],
              "example": "asc"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search term to filter todos by title or description (case-insensitive)",
            "schema": {
              "type": "string",
              "example": "grocery"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved todos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TodoListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token missing, invalid, or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/todos/{id}": {
      "get": {
        "tags": ["Todos"],
        "summary": "Get a specific todo",
        "description": "Retrieve a single todo by ID for the authenticated user",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Todo ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Todo retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/TodoResponse"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token missing, invalid, or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Todo not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Todos"],
        "summary": "Update a todo",
        "description": "Update an existing todo (all fields optional). Supports both PUT and PATCH methods",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Todo ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoUpdateRequest"
              },
              "examples": {
                "update_status": {
                  "value": {
                    "status": "in progress"
                  }
                },
                "update_title_and_description": {
                  "value": {
                    "title": "Updated title",
                    "description": "Updated description"
                  }
                },
                "complete_todo": {
                  "value": {
                    "status": "completed"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Todo updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Successfully updated the todo"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid JSON",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Please provide a valid json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token missing, invalid, or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - todo not found or belongs to another user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "Forbidden"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Todos"],
        "summary": "Partially update a todo",
        "description": "Update an existing todo with partial changes (all fields optional). Supports both PUT and PATCH methods",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Todo ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Todo updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Successfully updated the todo"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid JSON",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token missing, invalid, or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - todo not found or belongs to another user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Todos"],
        "summary": "Delete a todo",
        "description": "Delete a todo by marking it as completed (soft delete)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Todo ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Todo deleted successfully (no content returned)"
          },
          "400": {
            "description": "Bad request - invalid todo ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "message": "The mentioned id is invalid or deleted. Please select a valid todo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - token missing, invalid, or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication endpoints - register, login, and token refresh"
    },
    {
      "name": "Todos",
      "description": "Todo management endpoints - create, read, update, and delete operations"
    }
  ]
}
